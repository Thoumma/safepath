// SafeZone Response Console — data model
// One console for the Embassy, VFI and SafePath. Every SOS from the SafeZone
// mobile app becomes a Case that is routed to the partner who should handle it.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// A registered Lao traveller (owner of the SafeZone app / passport vault).
model Citizen {
  id            String           @id @default(uuid())
  fullName      String           @map("full_name")
  passportNo    String           @unique @map("passport_no")
  dob           DateTime?        @db.Date
  phone         String? // E.164, e.g. +85620...
  nationality   String           @default("LA")
  homeProvince  String?          @map("home_province")
  photoUrl      String?          @map("photo_url")
  // KYC: has a staff member confirmed this registration matches a real
  // passport? App self-registration lands as PENDING; only the console
  // moves it. The decision is also written to AuditLog.
  kycStatus     KycStatus        @default(PENDING) @map("kyc_status")
  kycReviewedBy String?          @map("kyc_reviewed_by")
  kycReviewedAt DateTime?        @map("kyc_reviewed_at")
  // Journey sharing: an *opt-in*, routine (non-emergency) location stream the
  // citizen switches on in the app so their trusted contacts — and the console
  // live map — can follow them while travelling. The latest fix is mirrored
  // here (like Case.lat/lng) so list views never need the breadcrumb table.
  // Freshness decides visibility: a flag left true with a stale lastJourneyAt
  // must render as "not sharing".
  journeySharing Boolean         @default(false) @map("journey_sharing")
  journeyLat     Float?          @map("journey_lat")
  journeyLng     Float?          @map("journey_lng")
  lastJourneyAt  DateTime?       @map("last_journey_at") @db.Timestamptz(3)
  createdAt     DateTime         @default(now()) @map("created_at")
  contacts      TrustedContact[]
  cases         Case[]
  journeyLocations JourneyLocation[]

  @@index([kycStatus])
  @@map("citizens")
}

/// Console audit trail for actions that are not tied to a single case (KYC
/// decisions, staff-level actions). Case-level history stays in CaseEvent;
/// the Activity Log page merges both.
model AuditLog {
  id        String   @id @default(uuid())
  actor     String
  action    String // kyc_verify | kyc_reject
  target    String?
  detail    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("audit_logs")
}

/// A pre-set Trusted Contact the SOS flow notifies.
model TrustedContact {
  id        String  @id @default(uuid())
  citizenId String  @map("citizen_id")
  citizen   Citizen @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  name      String
  phone     String // E.164
  email     String?
  relation  String?
  isPrimary Boolean @default(false) @map("is_primary")

  @@map("trusted_contacts")
}

/// A responding organisation: the Embassy, VFI, or SafePath.
model Partner {
  id         String      @id @default(uuid())
  code       PartnerType @unique
  name       String
  phone      String?
  responders Responder[]
  cases      Case[]
  staff      StaffUser[]

  @@map("partners")
}

/// A field responder that belongs to a Partner.
model Responder {
  id        String  @id @default(uuid())
  partnerId String  @map("partner_id")
  partner   Partner @relation(fields: [partnerId], references: [id])
  name      String
  phone     String?
  cases     Case[]

  @@map("responders")
}

/// The core entity: one SOS / assistance case.
model Case {
  id          String       @id @default(uuid())
  refNo       String       @unique @map("ref_no") // e.g. SOS-2026-0713-014
  citizenId   String       @map("citizen_id")
  citizen     Citizen      @relation(fields: [citizenId], references: [id])
  severity    Severity     @default(MEDIUM)
  status      CaseStatus   @default(NEW)
  type        String // free text, Lao, e.g. "ອຸບັດຕິເຫດ / Accident"
  city        String?
  country     String?
  lat         Float?
  lng         Float?
  routedTo    PartnerType?   @map("routed_to")
  partnerId   String?        @map("partner_id")
  partner     Partner?       @relation(fields: [partnerId], references: [id])
  responderId String?        @map("responder_id")
  responder   Responder?     @relation(fields: [responderId], references: [id])
  createdAt   DateTime       @default(now()) @map("created_at")
  resolvedAt  DateTime?      @map("resolved_at")
  events      CaseEvent[]
  locations   CaseLocation[]
  messages    CaseMessage[]

  @@index([status])
  @@index([routedTo])
  @@map("cases")
}

/// A live GPS breadcrumb for an open case.
///
/// While a case is open the SafeZone app posts a fresh fix on a fixed interval
/// (see the app's `LiveTrackingService`) to `POST /api/me/case/track`, which
/// appends one row here and copies the latest lat/lng onto the parent `Case`.
/// The trail lets a duty officer — and the user's trusted contacts — follow the
/// person *moving* instead of reading a single frozen point from when they first
/// pressed SOS. A one-shot SOS with no movement simply has one row (or none).
///
/// Distinct from [SosEvent]: that is a device-keyed, PostgREST-written ping with
/// no case attached; this is written through the authenticated `/api/me/*`
/// surface and belongs to a specific case, which is what both viewers query by.
model CaseLocation {
  id        String   @id @default(uuid())
  caseId    String   @map("case_id")
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  // Timestamptz for the same reason as everything else here: the user is abroad.
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([caseId, createdAt])
  @@map("case_locations")
}

/// A journey-sharing breadcrumb — citizen-scoped, deliberately *not* a case.
///
/// Journey sharing is a routine opt-in ("watch me while I travel"), not an
/// emergency: attaching it to Case would mint fake cases into the inbox and
/// pollute analytics. Written by `POST /api/me/journey/track`, which also
/// prunes each citizen's trail to the last 12 hours — a journey is a live
/// picture, not an archive, and keeping less is the privacy-correct default.
model JourneyLocation {
  id        String   @id @default(uuid())
  citizenId String   @map("citizen_id")
  citizen   Citizen  @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([citizenId, createdAt])
  @@map("journey_locations")
}

/// An entry on a case timeline (SOS received, forwarded, responder assigned...).
model CaseEvent {
  id        String   @id @default(uuid())
  caseId    String   @map("case_id")
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  kind      String   @default("note") // sos | route | assign | call | note | resolve
  message   String
  actor     String?
  createdAt DateTime @default(now()) @map("created_at")

  // The case page orders every timeline by exactly this pair on every load.
  @@index([caseId, createdAt])
  @@map("case_events")
}

/// One message in the two-way thread between a citizen and the duty officer.
///
/// Deliberately NOT a [CaseEvent]. That model is one-directional narration for
/// the officer's audit trail — no direction, no read state, no author identity.
/// Folding a conversation into it would make the timeline unreadable and the
/// audit trail unprovable. A case has both: a timeline of what was *done*, and
/// a thread of what was *said*.
///
/// Chat exists only while the case is open, and never for a DURESS case — the
/// device must not learn such a case exists (see `/api/me/case`). That rule is
/// enforced three times over: in the app-facing API, in the RLS policy
/// (`supabase/chat_policies.sql`), and by the app's own decoy gate.
model CaseMessage {
  id        String           @id @default(uuid())
  caseId    String           @map("case_id")
  case      Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  direction MessageDirection
  body      String

  /// Staff author; null for citizen messages. `authorName` is denormalised for
  /// display (mirroring CaseEvent.actor), `staffId` is the stable identity.
  staffId    String? @map("staff_id")
  authorName String? @map("author_name")

  /// App-generated uuid. Makes the offline outbox safe to retry: the same
  /// message re-sent after a failed flush collapses onto one row instead of
  /// posting twice. Null for staff messages, which are never queued.
  clientId String? @map("client_id")

  readByStaffAt   DateTime? @map("read_by_staff_at") @db.Timestamptz(3)
  readByCitizenAt DateTime? @map("read_by_citizen_at") @db.Timestamptz(3)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([caseId, clientId])
  @@index([caseId, createdAt])
  @@map("case_messages")
}

enum MessageDirection {
  FROM_CITIZEN
  FROM_STAFF
}

/// A location ping written directly by the SafeZone mobile app (via PostgREST
/// with the publishable key), not by this console. `sos` is the one-shot point
/// sent when the user confirms an SOS; `live` is a Phase-2 tracking point.
///
/// id/created_at use database-level defaults on purpose: the app inserts over
/// PostgREST and never supplies them, so Prisma's client-side @default(uuid())
/// would leave the column null.
model SosEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId  String   @map("device_id")
  lat       Float
  lng       Float
  mapsUrl   String?  @map("maps_url")
  type      String   @default("sos") // sos | live
  // Timestamptz, not timestamp: the user is abroad by definition, so a
  // zone-less emergency timestamp is ambiguous exactly when it matters.
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([deviceId])
  @@index([createdAt])
  @@map("sos_events")
}

/// A suspected human-trafficking report, modelled on STOP THE TRAFFIK's STOP
/// APP: anyone — a member of the public on the website, or a SafeZone app user —
/// can report something they saw, heard or suspect, and it lands in a staff
/// triage queue.
///
/// Deliberately decoupled from [Case]: a trafficking tip is anonymous by
/// default, needs no verified phone or citizen record, and has its own
/// lifecycle. Never key it to a real identity unless the reporter opts in via
/// [reporterContact].
model TraffikReport {
  id           String       @id @default(uuid())
  refNo        String       @unique @map("ref_no") // TIP-YYYY-MMDD-NNN
  category     String // labour | sexual | domestic | child | forced_marriage | other
  description  String
  country      String?
  city         String?
  locationText String?      @map("location_text") // free-text place ("near X market")
  lat          Float?
  lng          Float?
  observedAt   DateTime?    @map("observed_at") // when the reporter saw it
  photoUrls    String[]     @map("photo_urls") // optional evidence (Phase 6b)
  source       ReportSource @default(PUBLIC_WEB)
  // Anonymity is the promise. `anonymous` stays true unless the reporter chose
  // to leave a way to reach them; `reporterContact` is the only identifying
  // field and is null in the default flow.
  anonymous       Boolean   @default(true)
  reporterContact String?   @map("reporter_contact")
  status       ReportStatus @default(NEW)
  reviewNote   String?      @map("review_note")
  reviewedBy   String?      @map("reviewed_by")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([status])
  @@index([createdAt])
  @@map("traffik_reports")
}

/// Console-wide configuration set by staff at runtime (not env vars, which
/// need a redeploy). Today: the passport-verification API of the Lao Ministry
/// of Foreign Affairs (`passport_api_*` keys). Values are server-side only —
/// never sent to the client; the settings page shows the key masked.
model SystemSetting {
  key       String   @id
  value     String
  updatedBy String?  @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

/// A console operator. `id` mirrors the Supabase auth.users id.
model StaffUser {
  id          String       @id @default(uuid())
  email       String       @unique
  fullName    String?      @map("full_name")
  role        StaffRole    @default(OFFICER)
  partnerCode PartnerType? @map("partner_code")
  partnerId   String?      @map("partner_id")
  partner     Partner?     @relation(fields: [partnerId], references: [id])
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("staff_users")
}

enum PartnerType {
  EMBASSY
  VFI
  SAFEPATH
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum CaseStatus {
  NEW
  IN_PROGRESS
  RESOLVED
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum StaffRole {
  ADMIN // sees every case
  OFFICER // embassy duty officer, sees every case
  PARTNER // sees only cases routed to their partner
}

enum ReportSource {
  PUBLIC_WEB // the public website report form
  MOBILE_APP // the SafeZone app's Report tab
}

enum ReportStatus {
  NEW // just arrived, not yet triaged
  REVIEWING // an officer is looking into it
  ACTIONED // referred / escalated / acted on
  DISMISSED // not actionable (spam, insufficient, duplicate)
}
