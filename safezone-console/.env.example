# Copy to .env.local and fill in with values from your Supabase project.
# Never commit real credentials to this file.

# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[PUBLISHABLE_KEY]"

# Server-only secret (Dashboard → Project Settings → API → service_role).
# Enables private report-evidence photo storage (POST /api/report/photo). Leave
# unset to disable photos — reports stay text-only (fail-open). NEVER expose to
# the browser or ship in the app.
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"

# Firebase console → Project settings → Your apps → Web app config
NEXT_PUBLIC_FIREBASE_API_KEY="[FIREBASE_API_KEY]"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="[PROJECT_ID].firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="[PROJECT_ID]"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="[PROJECT_ID].firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="[SENDER_ID]"
NEXT_PUBLIC_FIREBASE_APP_ID="[APP_ID]"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="[MEASUREMENT_ID]"
